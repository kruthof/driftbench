{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ResearchBrief",
  "type": "object",
  "required": ["id", "domain", "objective", "hard_constraints", "success_criteria", "plausible_directions", "banned_moves"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+_[0-9]{2}$"
    },
    "domain": {
      "type": "string",
      "minLength": 3
    },
    "objective": {
      "type": "string",
      "minLength": 20
    },
    "hard_constraints": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 3,
      "maxItems": 8
    },
    "success_criteria": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2
    },
    "plausible_directions": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2,
      "maxItems": 5
    },
    "banned_moves": {
      "type": "array",
      "items": {"type": "string"},
      "minItems": 2,
      "maxItems": 5
    }
  },
  "additionalProperties": false
}
